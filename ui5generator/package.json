{
    "name": "ui5generator",
    "version": "0.0.1",
    "private": true,
    "description": "ui5generator description",
    "keywords": [
        "ui5",
        "openui5",
        "sapui5"
    ],
    "main": "webapp/index.html",
    "dependencies": {},
    "devDependencies": {
        "@ui5/cli": "^4.0.0",
        "@sap/ux-ui5-tooling": "1",
        "@ui5/linter": "latest",
        "@sap-ux/eslint-plugin-fiori-tools": "^0.2"
    },
    "scripts": {
        "prestart": "node scripts/write-app-config.cjs",
        "start": "fiori run --open index.html",
        "prequnit": "node scripts/write-app-config.cjs",
        "qunit": "fiori run --open test/unitTests.qunit.html",
        "prebuild": "node scripts/write-app-config.cjs",
        "build": "ui5 build --config=ui5.yaml --clean-dest --dest ../dist/ui5generator",
        "ui5lint": "ui5lint",
        "lint": "eslint ./"
    }
}
