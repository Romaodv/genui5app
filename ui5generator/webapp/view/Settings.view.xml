<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    controllerName="ui5generator.controller.Settings"
>
    <Page
        title="{i18n>settings.pageTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack"
    >
        <content>
            <VBox class="sapUiSmallMargin">
                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanM="4"
                    labelSpanS="12"
                    columnsM="1"
                    columnsL="1"
                >
                    <f:content>
                        <Label
                            text="{i18n>settings.backendType}"
                            labelFor="selectBackendType"
                        />
                        <Select
                            id="selectBackendType"
                            width="100%"
                            change=".onBackendTypeChange"
                        >
                            <items>
                                <core:Item
                                    id="itemBackendSaas"
                                    key="saas"
                                    text="{i18n>settings.backendSaas}"
                                />
                                <core:Item
                                    key="custom"
                                    text="{i18n>settings.backendCustom}"
                                />
                            </items>
                        </Select>
                    </f:content>
                </f:SimpleForm>

                <Panel
                    id="panelSaaS"
                    headerText="{i18n>settings.panelSaas}"
                    class="sapUiSmallMarginTop"
                >
                    <f:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsM="1"
                        columnsL="1"
                    >
                        <f:content>
                            <Label
                                id="labelManagedCredential"
                                text="{i18n>settings.apiKey}"
                                labelFor="inputApiKey"
                            />
                            <Input
                                id="inputApiKey"
                                type="Password"
                                width="100%"
                                placeholder="{i18n>settings.defaultApiKeyPlaceholder}"
                            />
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <Panel
                    id="panelBYO"
                    headerText="{i18n>settings.panelCustom}"
                    visible="false"
                    class="sapUiSmallMarginTop"
                >
                    <f:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsM="1"
                        columnsL="1"
                    >
                        <f:content>
                            <Label
                                text="{i18n>settings.endpoint}"
                                labelFor="inputEndpoint"
                            />
                            <Input
                                id="inputEndpoint"
                                width="100%"
                                placeholder="{i18n>settings.endpointPlaceholder}"
                            />

                            <Label
                                text="{i18n>settings.auth}"
                                labelFor="selectAuthType"
                            />
                            <Select
                                id="selectAuthType"
                                width="100%"
                                change=".onAuthTypeChange"
                            >
                                <items>
                                    <core:Item
                                        key="none"
                                        text="{i18n>settings.authNone}"
                                    />
                                    <core:Item
                                        key="apikey"
                                        text="{i18n>settings.authApiKey}"
                                    />
                                    <core:Item
                                        key="bearer"
                                        text="{i18n>settings.authBearer}"
                                    />
                                </items>
                            </Select>

                            <Label
                                id="labelToken"
                                text="{i18n>settings.tokenOrKey}"
                                labelFor="inputToken"
                            />
                            <Input
                                id="inputToken"
                                type="Password"
                                width="100%"
                            />
                        </f:content>
                    </f:SimpleForm>
                </Panel>
            </VBox>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    id="btnTest"
                    text="{i18n>button.testConnection}"
                    press=".onTestConnection"
                />
                <Button
                    text="{i18n>button.reset}"
                    press=".onClearSettings"
                />
                <Button
                    text="{i18n>button.save}"
                    type="Emphasized"
                    press=".onSaveSettings"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
