{
    "name": "ui5gen.open.ui5generator",
    "version": "0.0.1",
    "scripts": {
        "build": "mbt build --mtar ui5gen.open.ui5generator.mtar",
        "build:workspaces": "npm run build --workspaces --if-present",
        "deploy": "cf deploy mta_archives/ui5gen.open.ui5generator.mtar --retries 0",
        "lint": "npm run lint --workspaces --if-present",
        "test": "npm run test:wireframe",
        "test:wireframe": "node tests/wireframe-generator.test.cjs",
        "ui5lint": "npm run ui5lint --workspaces --if-present",
        "start:ui5generator": "npm start --workspace ui5generator",
        "qunit": "npm run qunit --workspace ui5generator"
    },
    "dependencies": {
        "mbt": "^1"
    },
    "workspaces": [
        "ui5generator"
    ]
}
